{"patcher":{"fileversion":1,"appversion":{"major":8,"minor":6,"revision":5,"architecture":"x64","modernui":1},"classnamespace":"dsp.gen","rect":[34,95,800,600],"bglocked":0,"openinpresentation":0,"default_fontsize":12,"default_fontface":0,"default_fontname":"Arial","gridonopen":1,"gridsize":[15,15],"gridsnaponopen":1,"objectsnaponopen":1,"statusbarvisible":2,"toolbarvisible":1,"lefttoolbarpinned":0,"toptoolbarpinned":0,"righttoolbarpinned":0,"bottomtoolbarpinned":0,"toolbars_unpinned_last_save":0,"tallnewobj":0,"boxanimatetime":200,"enablehscroll":1,"enablevscroll":1,"devicewidth":0,"description":"Lexicon 225-style reverb","digest":"","tags":"","style":"","subpatcher_template":"","assistshowspatchername":0,"boxes":[{"box":{"id":"obj-in1","maxclass":"newobj","numinlets":0,"numoutlets":1,"outlettype":[""],"patching_rect":[17,26,120,22],"text":"in 1 @comment mono_input"}},{"box":{"id":"obj-in2","maxclass":"newobj","numinlets":0,"numoutlets":1,"outlettype":[""],"patching_rect":[17,56,120,22],"text":"in 2 @comment decay"}},{"box":{"id":"obj-in3","maxclass":"newobj","numinlets":0,"numoutlets":1,"outlettype":[""],"patching_rect":[17,86,120,22],"text":"in 3 @comment predelay"}},{"box":{"id":"obj-in4","maxclass":"newobj","numinlets":0,"numoutlets":1,"outlettype":[""],"patching_rect":[17,116,120,22],"text":"in 4 @comment diffusion"}},{"box":{"id":"obj-in5","maxclass":"newobj","numinlets":0,"numoutlets":1,"outlettype":[""],"patching_rect":[17,146,120,22],"text":"in 5 @comment treble_decay"}},{"box":{"id":"obj-in6","maxclass":"newobj","numinlets":0,"numoutlets":1,"outlettype":[""],"patching_rect":[17,176,120,22],"text":"in 6 @comment crossover"}},{"box":{"id":"obj-in7","maxclass":"newobj","numinlets":0,"numoutlets":1,"outlettype":[""],"patching_rect":[17,206,120,22],"text":"in 7 @comment wet"}},{"box":{"id":"obj-codebox","maxclass":"codebox","fontface":0,"fontname":"<Monospaced>","fontsize":12,"numinlets":7,"numoutlets":2,"outlettype":["",""],"patching_rect":[16,71,600,400],"code":"// Lexicon 225-style reverb — Schroeder topology\n// Mono in (in1), stereo out (out1=L, out2=R)\n// Decay 0.1–60s, predelay, diffusion, treble decay, crossover, wet\n\n// ===== INLETS =====\ndecay = in2;\npredelay = in3;\ndiffusion = in4;\ntreble_decay = in5;\ncrossover = in6;\nwet = in7;\n\n// ===== HISTORY (crossover LPF) =====\nHistory lpf_prev(0.);\n\n// ===== CONSTANTS =====\nsr = SAMPLERATE;\ninv_sr = 1. / sr;\n\n// Comb delay lengths (samples, prime-ish, ~30–45ms at 48kHz)\nN1 = 1471.;\nN2 = 1789.;\nN3 = 1933.;\nN4 = 2113.;\n\n// Allpass delay lengths (Schroeder progression ~100ms/3^i)\nM1 = 331.;\nM2 = 109.;\nM3 = 37.;\n\n// ===== PREDELAY =====\npredelay_samps = mstosamps(predelay);\npredelayed = delay(96000., 1, in1, predelay_samps);\n\n// ===== CROSSOVER (one-pole 6dB/oct) =====\nlpf_coef = exp(-2. * 3.14159 * crossover * inv_sr);\nlow_band = lpf_coef * lpf_prev + (1. - lpf_coef) * predelayed;\nmid_band = predelayed - low_band;\nlpf_prev = low_band;\n\n// ===== DECAY COEFFICIENTS =====\ng_low_1 = t60(decay * 1.2 * sr / N1);\ng_low_2 = t60(decay * 1.2 * sr / N2);\ng_mid_3 = t60(decay * treble_decay * sr / N3);\ng_mid_4 = t60(decay * treble_decay * sr / N4);\n\n// ===== PARALLEL COMB FILTERS =====\nd1 = delay(96000., 1, c1_out, N1);\nc1_out = low_band + g_low_1 * d1;\n\nd2 = delay(96000., 1, c2_out, N2);\nc2_out = low_band + g_low_2 * d2;\n\nd3 = delay(96000., 1, c3_out, N3);\nc3_out = mid_band + g_mid_3 * d3;\n\nd4 = delay(96000., 1, c4_out, N4);\nc4_out = mid_band + g_mid_4 * d4;\n\n// ===== SUM COMB OUTPUTS =====\ncomb_sum = c1_out + c2_out + c3_out + c4_out;\n\n// ===== SERIES ALLPASS (diffusion) =====\nap1_in_d = delay(96000., 1, comb_sum, M1);\nap1_out_d = delay(96000., 1, ap1_out, M1);\nap1_out = -diffusion * comb_sum + ap1_in_d + diffusion * ap1_out_d;\n\nap2_in_d = delay(96000., 1, ap1_out, M2);\nap2_out_d = delay(96000., 1, ap2_out, M2);\nap2_out = -diffusion * ap1_out + ap2_in_d + diffusion * ap2_out_d;\n\nap3_in_d = delay(96000., 1, ap2_out, M3);\nap3_out_d = delay(96000., 1, ap3_out, M3);\nap3_out = -diffusion * ap2_out + ap3_in_d + diffusion * ap3_out_d;\n\n// ===== STEREO MIXING MATRIX =====\ns1 = c1_out + c3_out;\ns2 = c2_out + c4_out;\nwet_l = ap3_out * 0.7 + (s1 + s2) * 0.15;\nwet_r = ap3_out * 0.7 + (s1 - s2) * 0.15;\n\n// ===== DRY/WET MIX =====\ndry = in1;\nout1 = dry * (1. - wet) + wet_l * wet;\nout2 = dry * (1. - wet) + wet_r * wet;"}},{"box":{"id":"obj-out1","maxclass":"newobj","numinlets":1,"numoutlets":0,"patching_rect":[16,500,120,22],"text":"out 1 @comment L"}},{"box":{"id":"obj-out2","maxclass":"newobj","numinlets":1,"numoutlets":0,"patching_rect":[16,530,120,22],"text":"out 2 @comment R"}}],"lines":[{"patchline":{"destination":["obj-codebox",0],"source":["obj-in1",0]}},{"patchline":{"destination":["obj-codebox",1],"source":["obj-in2",0]}},{"patchline":{"destination":["obj-codebox",2],"source":["obj-in3",0]}},{"patchline":{"destination":["obj-codebox",3],"source":["obj-in4",0]}},{"patchline":{"destination":["obj-codebox",4],"source":["obj-in5",0]}},{"patchline":{"destination":["obj-codebox",5],"source":["obj-in6",0]}},{"patchline":{"destination":["obj-codebox",6],"source":["obj-in7",0]}},{"patchline":{"destination":["obj-out1",0],"source":["obj-codebox",0]}},{"patchline":{"destination":["obj-out2",0],"source":["obj-codebox",1]}}]}}
